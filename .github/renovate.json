{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["local>sparetimecoders/renovate-config"],
  "postUpdateOptions": ["gomodTidy"],
  "packageRules": [
    {
      "extends": ["monorepo:aws-sdk-go-v2"],
      "groupName": "aws-sdk-go-v2 monorepo"
    },
    {
      "description": "Auto-merge golang Docker image patches on weekends",
      "matchManagers": ["dockerfile"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "schedule": ["every weekend after 4am"],
      "matchPackageNames": ["/golang/"]
    },
    {
      "description": "Auto-merge debian Docker images on weekends",
      "matchManagers": ["dockerfile"],
      "versioning": "regex:^(?<compatibility>[a-z]+?)-(?<minor>\\d+)?-[a-z]+?$",
      "automerge": true,
      "schedule": ["every weekend after 4am"],
      "matchPackageNames": ["/debian/"]
    }
  ]
}
